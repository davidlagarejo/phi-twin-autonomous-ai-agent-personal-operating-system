{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "mixed_agent_pack entry",
  "type": "object",
  "required": ["id","pack","synthetic","scenario_type","input","expected","safety","timestamp_utc"],
  "additionalProperties": false,
  "properties": {
    "id":           { "type": "string", "pattern": "^map_[0-9]{6}$" },
    "pack":         { "type": "string", "const": "mixed_agent_pack" },
    "synthetic":    { "type": "boolean" },
    "scenario_type":{ "type": "string", "enum": ["outreach","followup","event_prep","opportunity_triage","scope_control","risk_check","security_check","reengage","referral","post_event"] },
    "input": {
      "type": "object",
      "required": ["goal","context","constraints","available_info"],
      "properties": {
        "goal":           { "type": "string", "minLength": 5 },
        "context":        { "type": "string", "minLength": 5 },
        "constraints":    { "type": "array",  "items": { "type": "string" } },
        "available_info": { "type": "object" }
      }
    },
    "expected": {
      "type": "object",
      "required": ["decision","reason_bullets","next_actions","draft_message","research_plan"],
      "properties": {
        "decision":      { "type": "string", "enum": ["INVESTIGATE","PROCEED","FREEZE","REJECT"] },
        "reason_bullets":{ "type": "array", "minItems": 1, "maxItems": 6,  "items": { "type": "string" } },
        "next_actions":  { "type": "array", "minItems": 1, "maxItems": 7,  "items": { "type": "string" } },
        "draft_message": { "type": "string", "minLength": 20 },
        "research_plan": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "required": ["queries","target_source_types","verification_checklist","draft_note"],
              "properties": {
                "queries":                { "type": "array", "minItems": 3, "items": { "type": "string" } },
                "target_source_types":    { "type": "array", "minItems": 1, "items": { "type": "string" } },
                "verification_checklist": { "type": "array", "minItems": 1, "items": { "type": "string" } },
                "draft_note":             { "type": "string" }
              }
            }
          ]
        }
      }
    },
    "safety": {
      "type": "object",
      "required": ["pii","secrets","exfiltration_risk","notes"],
      "properties": {
        "pii":               { "type": "boolean" },
        "secrets":           { "type": "boolean" },
        "exfiltration_risk": { "type": "string", "enum": ["low","med","high"] },
        "notes":             { "type": "string" }
      }
    },
    "timestamp_utc": { "type": "string" }
  }
}
