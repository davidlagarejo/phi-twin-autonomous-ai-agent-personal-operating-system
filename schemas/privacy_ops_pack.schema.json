{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "privacy_ops_pack entry",
  "type": "object",
  "required": ["id","lang","category","task","expected","labels"],
  "additionalProperties": false,
  "properties": {
    "id": {"type": "string", "pattern": "^ops_[0-9]{6}$"},
    "lang": {"type": "string", "enum": ["es","en"]},
    "category": {"type": "string", "enum": ["privacy_gate","claude_request","claude_error_report","web_query","redaction","block"]},
    "task": {
      "type": "object",
      "required": ["user_intent","raw_input","environment"],
      "additionalProperties": false,
      "properties": {
        "user_intent": {"type": "string", "minLength": 5},
        "raw_input": {
          "type": "object",
          "required": ["contains_private","private_fields","content"],
          "additionalProperties": false,
          "properties": {
            "contains_private": {"type": "boolean"},
            "private_fields": {"type": "array", "items": {"type": "string", "enum": ["names","companies","clients","emails","phone","addresses","dates","money","doc_text","event_details","identifiers"]}},
            "content": {"type": "string", "minLength": 1}
          }
        },
        "environment": {
          "type": "object",
          "required": ["searxng_is_local","claude_is_remote"],
          "additionalProperties": false,
          "properties": {
            "searxng_is_local": {"type": "boolean"},
            "claude_is_remote": {"type": "boolean"}
          }
        }
      }
    },
    "expected": {
      "type": "object",
      "required": ["privacy_gate","routing","safe_payload","local_plan","error_report_if_any","user_questions_if_blocked","success_criteria"],
      "additionalProperties": false,
      "properties": {
        "privacy_gate": {
          "type": "object",
          "required": ["exfil_risk","reason","redaction_notes"],
          "additionalProperties": false,
          "properties": {
            "exfil_risk": {"type": "string", "enum": ["ALLOW","REDACT_AND_PROCEED","BLOCK"]},
            "reason": {"type": "string", "minLength": 5},
            "redaction_notes": {"type": "array", "items": {"type": "string"}}
          }
        },
        "routing": {
          "type": "object",
          "required": ["preferred_action"],
          "additionalProperties": false,
          "properties": {
            "preferred_action": {"type": "string", "enum": ["ASK_CLAUDE","SEARCH_WEB","RESPOND_DIRECT","BLOCK"]}
          }
        },
        "safe_payload": {
          "type": "object",
          "required": ["to_claude","to_web"],
          "additionalProperties": false,
          "properties": {
            "to_claude": {
              "type": "object",
              "required": ["allowed","message"],
              "additionalProperties": false,
              "properties": {
                "allowed": {"type": "boolean"},
                "message": {"type": "string"}
              }
            },
            "to_web": {
              "type": "object",
              "required": ["allowed","query"],
              "additionalProperties": false,
              "properties": {
                "allowed": {"type": "boolean"},
                "query": {"type": "string"}
              }
            }
          }
        },
        "local_plan": {"type": "array", "items": {"type": "string"}},
        "error_report_if_any": {
          "type": "object",
          "required": ["allowed_to_send_to_claude","node","expected_type","received_type","where","error_text","minimal_synthetic_repro"],
          "additionalProperties": false,
          "properties": {
            "allowed_to_send_to_claude": {"type": "boolean"},
            "node": {"type": "string"},
            "expected_type": {"type": "string"},
            "received_type": {"type": "string"},
            "where": {"type": "string"},
            "error_text": {"type": "string"},
            "minimal_synthetic_repro": {"type": "string"}
          }
        },
        "user_questions_if_blocked": {"type": "array", "items": {"type": "string"}},
        "success_criteria": {"type": "array", "items": {"type": "string"}, "minItems": 1}
      }
    },
    "labels": {
      "type": "object",
      "required": ["pii_leak","policy_compliant","severity"],
      "additionalProperties": false,
      "properties": {
        "pii_leak": {"type": "boolean"},
        "policy_compliant": {"type": "boolean"},
        "severity": {"type": "string", "enum": ["low","medium","high"]}
      }
    }
  }
}
